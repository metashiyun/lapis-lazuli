---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getDocsByGroup } from "../lib/docs";

const principles = [
  {
    title: "Author in TypeScript or Python",
    body: "Use familiar scripting languages instead of building against Java."
  },
  {
    title: "Ship to the JVM",
    body: "Drop bundles into a Paper or Bukkit server and let the runtime manage loading."
  },
  {
    title: "Iterate quickly",
    body: "Replace bundle files and rely on hot reload while the server stays online."
  }
];

const steps = [
  {
    title: "Create a plugin",
    detail: "Scaffold a project with a manifest and either a TypeScript or Python entrypoint."
  },
  {
    title: "Bundle it",
    detail: "Validate the manifest and package the runtime-ready bundle structure."
  },
  {
    title: "Load it on the server",
    detail: "Build the runtime plugin, copy the bundle into the Lapis Lazuli bundles directory, and let the server pick it up."
  }
];

const docGroups = getDocsByGroup();
---

<BaseLayout
  title="Lapis Lazuli"
  description="Lapis Lazuli lets plugin authors build lightweight Minecraft server plugins in TypeScript or Python and run them on Paper or Bukkit."
>
  <main class="page-shell">
    <header class="site-header">
      <div class="topbar">
        <a class="brand" href="/">Lapis Lazuli</a>
        <div class="topbar-links">
          <a class="hero-link" href="/docs">Docs</a>
          <a class="hero-link" href="https://github.com/metashiyun/lapis-lazuli">GitHub</a>
        </div>
      </div>
    </header>

    <section class="hero">
      <div class="hero-copy">
        <h1>Write Minecraft plugins without touching Java.</h1>
        <p class="lede">
          Lapis Lazuli is a library for writing Minecraft plugins in TypeScript or Python,
          with a runtime that lets those plugins run naturally on Paper and Bukkit
          servers.
        </p>

        <div class="hero-actions">
          <a class="hero-action" href="/docs">Read the docs</a>
          <a class="hero-action secondary" href="https://github.com/metashiyun/lapis-lazuli">
            Browse source
          </a>
        </div>
      </div>

      <div class="hero-pattern" aria-hidden="true"></div>
    </section>

    <section class="section">
      <div class="section-heading">
        <p class="section-label">Overview</p>
        <h2>A small idea, kept small.</h2>
      </div>

      <div class="simple-grid">
        {principles.map(({ title, body }) => (
          <article class="simple-item">
            <h3>{title}</h3>
            <p>{body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="how-it-works">
      <div class="section-heading">
        <p class="section-label">Workflow</p>
        <h2>From source files to a running server.</h2>
      </div>

      <div class="workflow-layout">
        <div class="step-list">
          {steps.map(({ title, detail }, index) => (
            <article class="step-item">
              <span class="step-number">0{index + 1}</span>
              <div class="step-copy">
                <h3>{title}</h3>
                <p>{detail}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section" id="docs">
      <div class="section-heading">
        <p class="section-label">Documentation</p>
        <h2>The repo docs now live inside the site.</h2>
      </div>

      <div class="docs-preview-grid">
        {docGroups.map((group) => (
          <article class="docs-preview-card">
            <p class="docs-preview-label">{group.label}</p>
            <h3>{group.description}</h3>

            <div class="docs-preview-list">
              {group.docs.map((doc) => (
                <a class="docs-preview-item" href={doc.url}>
                  {doc.title}
                </a>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="closing">
      <h2>
        built by <a class="closing-link" href="https://shiyun.org">metaShiyun</a>.
      </h2>
    </section>
  </main>
</BaseLayout>
