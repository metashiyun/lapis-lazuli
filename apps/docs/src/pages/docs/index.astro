---
import DocsLayout from "../../layouts/DocsLayout.astro";
import { getDocs, getDocsHome } from "../../lib/docs";

const doc = getDocsHome();
const [nextDoc] = getDocs();
const Content = doc.Content;
---

<DocsLayout
  title={`${doc.title} | Lapis Lazuli Docs`}
  description={doc.description}
  currentPath="/docs"
>
  <article class="docs-article docs-doc-home">
    <header class="docs-article-meta">
      <div class="docs-meta-links docs-page-actions">
        <a href={doc.markdownUrl}>Markdown</a>
        <a href={doc.sourceUrl}>Source</a>
      </div>
    </header>

    <div class="docs-prose">
      <Content />
    </div>

    {nextDoc && (
      <nav class="docs-article-pager" aria-label="Document pagination">
        <a class="docs-pager-link" href={nextDoc.url}>
          <span>Next</span>
          <strong>{nextDoc.title}</strong>
        </a>
      </nav>
    )}
  </article>
</DocsLayout>
