---
import DocsLayout from "../../layouts/DocsLayout.astro";
import { getDocsByGroup, repoBaseUrl, repoDocsUrl } from "../../lib/docs";

const docGroups = getDocsByGroup();

const quickLinks = [
  {
    label: "Project home",
    href: "/"
  },
  {
    label: "Repository README",
    href: `${repoBaseUrl}/blob/main/README.md`
  },
  {
    label: "Raw docs directory",
    href: repoDocsUrl
  }
];
---

<DocsLayout
  title="Documentation | Lapis Lazuli"
  description="Technical docs for the runtime, SDKs, CLI, and plugin authoring workflow."
  currentPath="/docs"
>
  <section class="docs-home">
    <div class="docs-home-intro">
      <p class="docs-kicker">Documentation</p>
      <h1>Runtime notes, API reference, and authoring guides in one place.</h1>
      <p class="docs-home-copy">
        This site exposes the Markdown docs from the repository itself, grouped by the way
        plugin authors usually move through the project: orientation first, contract
        details next, then end-to-end workflow guidance.
      </p>
    </div>

    <div class="docs-quick-links">
      {quickLinks.map((link) => (
        <a class="docs-quick-link" href={link.href}>{link.label}</a>
      ))}
    </div>

    <div class="docs-section-grid">
      {docGroups.map((group) => (
        <section class="docs-section-card">
          <p class="docs-kicker">{group.label}</p>
          <h2>{group.description}</h2>

          <div class="docs-link-list">
            {group.docs.map((doc) => (
              <a class="docs-link-card" href={doc.url}>
                <span class="docs-link-title">{doc.title}</span>
                <span class="docs-link-copy">{doc.description}</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>
</DocsLayout>
