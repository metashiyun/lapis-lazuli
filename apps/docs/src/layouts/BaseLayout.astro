---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  pageClass?: string;
}

const {
  title = "Lapis Lazuli",
  description = "Zero-Java authoring for lightweight Minecraft server plugins.",
  pageClass = ""
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body class={pageClass}>
    <slot />
  </body>
</html>
