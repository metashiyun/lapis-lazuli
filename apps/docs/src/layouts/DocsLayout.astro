---
import BaseLayout from "./BaseLayout.astro";
import { getDocsByGroup } from "../lib/docs";

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
}

const {
  title = "Documentation | Lapis Lazuli",
  description = "Technical documentation for the Lapis Lazuli runtime, SDKs, and authoring workflow.",
  currentPath = "/docs"
} = Astro.props;

const navGroups = getDocsByGroup();
---

<BaseLayout title={title} description={description} pageClass="docs-page">
  <div class="docs-app">
    <aside class="docs-sidebar" aria-label="Documentation navigation">
      <div class="docs-sidebar-header">
        <a class="docs-brand" href="/">Lapis Lazuli</a>
      </div>

      <div class="docs-nav-stack">
        <a
          class:list={["docs-sidebar-home", currentPath === "/docs" && "active"]}
          href="/docs"
        >
          Overview
        </a>

        {navGroups.map((group) => (
          <section class="docs-nav-section">
            <p class="docs-nav-label">{group.label}</p>

            <ul class="docs-nav-list">
              {group.docs.map((doc) => (
                <li>
                  <a
                    class:list={["docs-nav-link", currentPath === doc.url && "active"]}
                    href={doc.url}
                    aria-current={currentPath === doc.url ? "page" : undefined}
                  >
                    {doc.title}
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))}
      </div>

      <div class="docs-sidebar-footer">
        <a class="docs-utility-link" href="/agents/index.md">Agents</a>
        <a class="docs-utility-link" href="https://github.com/metashiyun/lapis-lazuli">GitHub</a>
      </div>
    </aside>

    <main class="docs-main">
      <slot />
    </main>
  </div>
</BaseLayout>
